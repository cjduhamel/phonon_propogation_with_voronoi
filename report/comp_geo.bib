@article{muckeFastRandomizedPoint,
  title = {Fast Randomized Point Location without Preprocessing in Two- and Three-Dimensional {{Delaunay}} Triangulations},
  author = {Mücke, Ernst P and Saias, Isaac and Zhu, Binhai},
  abstract = {This paper studies the point location problem in Delaunay triangulations without preprocessing and additional storage. The proposed procedure finds the query point by simply “walking through” the triangulation, after selecting a “good starting point” by random sampling. The analysis generalizes and extends a recent result for d = 2 dimensions by proving this procedure takes expected time close to O(n1/(d+1)) for point location in Delaunay triangulations of n random points in d = 3 dimensions. Empirical results in both two and three dimensions show that this procedure is efficient in practice.  1999 Elsevier Science B.V. All rights reserved.},
  langid = {english},
  annotation = {muckeFastRandomizedPoint},
  file = {/Users/cjduhamel/Zotero/storage/B886GY3H/Mücke et al. - Fast randomized point location without preprocessing in two- and three-dimensional Delaunay triangul.pdf}
}

